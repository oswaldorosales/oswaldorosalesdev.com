# NPM configuration ultra-optimized for 2GB RAM builds
# Reduce concurrent connections to minimum (prevents memory spikes)
maxsockets=1

# Increase retries for unstable connections
fetch-retries=10
fetch-retry-mintimeout=30000
fetch-retry-maxtimeout=180000

# Use local cache to reduce downloads
prefer-offline=true

# Disable unnecessary operations that consume RAM
audit=false
fund=false
progress=false
loglevel=error

# Prefer deduplication to reduce node_modules size
prefer-dedupe=true

# Skip optional dependencies (reduce compilation overhead)
optional=false
