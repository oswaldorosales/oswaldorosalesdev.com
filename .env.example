# Zoho Email Configuration
# Used for contact form submissions via SMTP

# Your Zoho email address
ZOHO_EMAIL=your_zoho_email_here

# Zoho App Password (NOT your regular password)
# Generate at: https://accounts.zoho.com/home#security/application-specific-passwords
ZOHO_APP_PASSWORD=your_app_password_here

# Google reCAPTCHA v3 Configuration
# Get your keys at: https://www.google.com/recaptcha/admin

# Public site key (visible in client-side code)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Secret key (server-side only, keep private)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
